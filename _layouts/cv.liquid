---
layout: default
---

<style>
  .cv {
    line-height: 1.62;
  }

  .cv .card {
    margin-top: 1.15rem !important;
    padding: 1.15rem 1.25rem !important;
    border-color: color-mix(in srgb, var(--global-divider-color) 72%, transparent);
  }

  .cv .card-title {
    margin-bottom: 0.9rem;
    font-size: 1.18rem;
  }

  .cv .card p {
    margin-bottom: 0.35rem;
  }

  .cv .card-text {
    line-height: 1.62;
  }

  .cv .cv-markdown-list {
    list-style: disc;
    margin: 0.1rem 0 0.85rem 1.25rem;
    padding-left: 1rem;
  }

  .cv .cv-list-label {
    margin-top: 0.35rem;
    margin-bottom: 0.15rem;
  }

  .cv .cv-markdown-list li {
    margin-bottom: 0.28rem;
    padding-left: 0.1rem;
    line-height: 1.58;
  }

  .cv .cv-markdown-sublist {
    list-style-type: circle;
    margin-top: 0.18rem;
    margin-bottom: 0.45rem;
  }

  .cv .cv-markdown-list li:last-child {
    margin-bottom: 0;
  }

  .cv .list-group-item {
    padding: 0.55rem 0 !important;
    line-height: 1.58;
  }

  .cv .card-text.list-group .list-group-item:not(:has(.row)) {
    position: relative;
    padding-left: 1.05rem !important;
  }

  .cv .card-text.list-group .list-group-item:not(:has(.row))::before {
    content: "";
    position: absolute;
    left: 0.2rem;
    top: 1.02em;
    width: 0.32rem;
    height: 0.32rem;
    border-radius: 50%;
    background: var(--global-theme-color);
  }

  .cv .list-group-flush > .list-group-item:first-child {
    padding-top: 0 !important;
  }

  .cv .list-group-flush > .list-group-item:last-child {
    padding-bottom: 0 !important;
  }

  .cv table.table-cv td,
  .cv table.table-cv th {
    padding: 0.16rem 0.28rem;
  }

  .cv .date-column {
    padding-top: 0.18rem;
  }

  .cv .badge {
    line-height: 1.25;
    padding: 0.26rem 0.5rem;
  }

  .cv .award-date-badge {
    align-items: center;
    display: inline-flex;
    justify-content: center;
    min-width: 6.5rem;
    text-align: center;
  }

  .cv h6.title {
    margin-bottom: 0.28rem;
  }

  .cv ul.items {
    margin-top: 0.45rem;
    margin-bottom: 0;
    padding-left: 1.2rem;
  }

  .cv ul.items li {
    margin-bottom: 0.28rem;
    line-height: 1.55;
  }

  .cv .card-text.font-weight-light > div {
    margin-bottom: 0.45rem;
  }

  .cv .card-text.font-weight-light > div:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 575.98px) {
    .cv .card {
      padding: 1rem !important;
    }

    .cv .list-group-item .row {
      row-gap: 0.35rem;
    }

    .cv .date-column {
      margin-bottom: 0.25rem;
      text-align: left !important;
    }
  }
</style>

{% assign cv_feature_enabled = site.al_folio.features.cv.enabled | default: true %}

{% if site.plugins contains 'al_folio_cv' and cv_feature_enabled %}
  {% al_folio_cv_render %}
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">CV rendering is unavailable.</p>
    </header>
    <article>
      <p>Enable the <code>al_folio_cv</code> plugin and set <code>al_folio.features.cv.enabled: true</code> to render this page.</p>
    </article>
  </div>
{% endif %}
